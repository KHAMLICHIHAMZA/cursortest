# Database
DATABASE_URL="postgresql://postgres:Greenboys05.@localhost:5432/malocauto?schema=public"
# Même URL en local ; sur Neon : URL « pooled » pour DATABASE_URL, URL « direct » (hôte sans -pooler) pour DIRECT_URL.
DIRECT_URL="postgresql://postgres:Greenboys05.@localhost:5432/malocauto?schema=public"

# Optionnel (prod Neon / CI) : évite P1002 si le verrou advisory expire au démarrage. Ne pas lancer 2 migrate deploy en parallèle.
# PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Frontend URLs (for CORS + reset password links)
FRONTEND_URL=http://localhost:3100
FRONTEND_WEB_URL=http://localhost:3100
FRONTEND_ADMIN_URL=http://localhost:5173

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@malocauto.com

# Stockage S3-compatible (optionnel) — ex. Cloudflare R2, AWS S3, MinIO
# Si les 4 premières lignes + S3_PUBLIC_BASE_URL sont remplies, l’upload d’image véhicule
# (POST /vehicles/upload-image) envoie le fichier sur le bucket et retourne une URL HTTPS
# absolue ; sinon le fichier reste sur le disque (UPLOAD_PATH / uploads/) comme avant.
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
# R2: souvent "auto" ; AWS: ex. "eu-west-1"
S3_REGION=auto
# URL publique des assets (sans slash final) — ex. https://pub-xxxxx.r2.dev
S3_PUBLIC_BASE_URL=
# R2 / MinIO: souvent "true" quand S3_ENDPOINT est renseigné
S3_FORCE_PATH_STYLE=

# CMI Payment (Maroc)
CMI_MERCHANT_ID=
CMI_SECRET_KEY=
CMI_TEST_MODE=true

# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# AI Services
OPENAI_API_KEY=
VISION_API_KEY=

# 2FA
TWO_FACTOR_ISSUER=MalocAuto
