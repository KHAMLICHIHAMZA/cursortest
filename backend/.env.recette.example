# Backend recipe/preprod environment example
# Copy to backend/.env and fill real values

# Server
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/malocauto?schema=public"

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URLs (CORS)
FRONTEND_URL=https://web-recette.example.com
FRONTEND_AGENCY_URL=https://agency-recette.example.com
MOBILE_WEB_URL=https://mobile-recette.example.com

# Upload Path (optional)
# UPLOAD_PATH=/var/www/malocauto-uploads

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@malocauto.com

# S3 Compatible Storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=

# CMI Payment
CMI_MERCHANT_ID=
CMI_SECRET_KEY=
CMI_TEST_MODE=true

# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# AI Services
OPENAI_API_KEY=
VISION_API_KEY=

# 2FA
TWO_FACTOR_ISSUER=MalocAuto
