# Copier vers la racine du dossier frontend-web :  .env.e2e.preprod
# (fichier ignoré par git — ne pas committer les mots de passe)
#
# Ensuite :  npm run test:e2e:preprod
#
# Sans fichier .env, les URLs par défaut préprod sont déjà appliquées quand E2E_TARGET=preprod.

E2E_TARGET=preprod

# Surcharge optionnelle (sinon défauts Maloc préprod)
# PLAYWRIGHT_BASE_URL=https://votre-front.vercel.app
# PLAYWRIGHT_API_URL=https://votre-api.onrender.com/api/v1

E2E_ADMIN_EMAIL=admin@malocauto.com
E2E_ADMIN_PASSWORD=

E2E_AGENT_EMAIL=
E2E_AGENT_PASSWORD=
